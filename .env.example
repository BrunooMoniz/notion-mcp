NOTION_GLOBALCRIPTO_TOKEN=ntn_xxx
NOTION_PERSONAL_TOKEN=ntn_xxx
NOTION_NORA_TOKEN=ntn_xxx
BEARER_TOKEN=generate-with-openssl-rand-hex-32
BASE_URL=https://your-vps.example.net
OAUTH_PASSWORD_HASH=salt:hash

# RAG (new in Fase 1)
VOYAGE_API_KEY=pa-xxx
POSTGRES_URL=postgresql://brain:password@localhost:5432/brain
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIM=1024
INDEXER_CRON=0 * * * *

# Reranker (Fundação F.1) — Voyage cross-encoder over the candidate pool
RERANK_MODEL=rerank-2.5-lite
# Kill switch: RERANK_ENABLED=false hard-disables rerank regardless of the
# per-call opt (graceful fallback to normalized RRF). Unset/true = enabled.
RERANK_ENABLED=true
# Index raw Granola transcripts (noise + sensitive content). Default false:
# only the summary is indexed. Set true to also index the full transcript.
GRANOLA_INDEX_TRANSCRIPT=false

# OAuth token lifetime in ms (Fundação F.4). Short TTL = more secure, more
# frequent re-login. 4h = 14400000. (The credential-store directory is NOT an
# env var — the stores live at the hardcoded <repo>/data/ path.)
TOKEN_TTL_MS=14400000
