NOTION_GLOBALCRIPTO_TOKEN=ntn_xxx
NOTION_PERSONAL_TOKEN=ntn_xxx
NOTION_NORA_TOKEN=ntn_xxx
BEARER_TOKEN=generate-with-openssl-rand-hex-32
BASE_URL=https://your-vps.example.net
OAUTH_PASSWORD_HASH=salt:hash
# OAuth token lifetimes. Apply only to NEWLY-issued tokens; existing persisted
# tokens keep their stored expiry. Sane defaults if unset.
OAUTH_ACCESS_TTL_HOURS=24
OAUTH_REFRESH_TTL_DAYS=90

# RAG (new in Fase 1)
VOYAGE_API_KEY=pa-xxx
POSTGRES_URL=postgresql://brain:password@localhost:5432/brain
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIM=1024
INDEXER_CRON=0 * * * *

# Reranker (Fundação F.1) — Voyage cross-encoder over the candidate pool
RERANK_MODEL=rerank-2.5-lite
# Kill switch: RERANK_ENABLED=false hard-disables rerank regardless of the
# per-call opt (graceful fallback to normalized RRF). Unset/true = enabled.
RERANK_ENABLED=true
# Index raw Granola transcripts (noise + sensitive content). Default false:
# only the summary is indexed. Set true to also index the full transcript.
GRANOLA_INDEX_TRANSCRIPT=false

# Calendars (iCal) — simplest way to index multiple calendars, no Google Cloud.
# For each calendar: Google Calendar -> Settings and sharing -> "Integrate
# calendar" -> copy "Secret address in iCal format" (ends in /basic.ics).
# These URLs are SECRETS (anyone with one can read that calendar) — keep them
# here only, never commit; reset a leaked URL in the same settings page.
# JSON array of {url, label, workspace}; workspace is personal|globalcripto|nora.
GOOGLE_CAL_ICS=[{"url":"https://calendar.google.com/calendar/ical/<id>/private-<key>/basic.ics","label":"Pessoal","workspace":"personal"}]

# Alternative (advanced): Google OAuth calendar indexer instead of iCal. Needs a
# Google Cloud OAuth client + visiting /google/connect. The iCal route above is
# preferred (simpler, account-agnostic, no Cloud Console). If GOOGLE_CAL_ICS is
# set it takes precedence and these are ignored.
# GOOGLE_OAUTH_CLIENT_ID=...
# GOOGLE_OAUTH_CLIENT_SECRET=...
# GOOGLE_CAL_WORKSPACE_MAP={"you@gmail.com":{"workspace":"personal"}}

# Daily briefing worker (runs in brain-classifier). Each morning it writes a
# PT-BR briefing — today's agenda + per-meeting prep + top open/overdue tasks —
# to the "Hoje" Notion page.
# Cron schedule (node-cron). Default 07:00 daily.
BRIEFING_CRON=0 7 * * *
# Notion page id of the "Hoje" page to overwrite each morning. REQUIRED for the
# briefing to write — if unset, the worker logs a warning and writes nothing
# (it never guesses a page). Page must be shared with NOTION_PERSONAL_TOKEN.
BRIEFING_PAGE_ID=

# FACTS_ENABLED=true   # F2.3 temporal facts extraction (default off)

# F2.2 — optional periodic web feed (NOT a secret; just URLs + workspace). The
# indexer fetches each entry hourly. On-demand single-URL capture uses the
# brain_index_web MCP tool instead. JSON array of {url, workspace, label?}.
# WEB_SOURCES=[{"url":"https://example.com/article","workspace":"personal","label":"Some blog"}]
